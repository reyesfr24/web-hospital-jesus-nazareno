---
const nav = [
  { label: 'Inicio',      href: '/' },
  { label: 'Servicios',   href: '/servicios' },
  { label: 'Instalaciones', href: '/instalaciones' },
  { label: 'Equipo',      href: '/equipo' },
  { label: 'Admisión',    href: '/admision' },
  { label: 'Noticias',    href: '/noticias' },
  { label: 'FAQ',         href: '/faq' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 focus-visible:outline rounded" aria-label="Hospital Jesús Nazareno - Inicio">
        <span class="text-lg md:text-xl font-semibold text-primary-800 leading-tight">
          Hospital<br class="hidden sm:block" />
          <span class="text-warm-600">Jesús Nazareno</span>
        </span>
      </a>

      <!-- Nav escritorio -->
      <nav aria-label="Navegación principal" class="hidden lg:flex items-center gap-1">
        {nav.map(({ label, href }) => (
          <a
            href={href}
            aria-current={currentPath === href ? 'page' : undefined}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md transition-colors duration-150 focus-visible:outline',
              currentPath === href
                ? 'text-primary-700 bg-primary-50'
                : 'text-gray-600 hover:text-primary-700 hover:bg-gray-50',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- CTA escritorio -->
      <a href="/contacto" class="hidden lg:inline-flex btn-primary text-sm">
        Solicitar información
      </a>

      <!-- Botón menú móvil -->
      <button
        id="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
        class="lg:hidden p-2 rounded-md text-gray-600 hover:text-primary-700 hover:bg-gray-100 focus-visible:outline"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <nav aria-label="Navegación móvil" class="section-container py-3 flex flex-col gap-1">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          aria-current={currentPath === href ? 'page' : undefined}
          class:list={[
            'px-3 py-2.5 text-sm font-medium rounded-md transition-colors duration-150',
            currentPath === href
              ? 'text-primary-700 bg-primary-50'
              : 'text-gray-700 hover:text-primary-700 hover:bg-gray-50',
          ]}
        >
          {label}
        </a>
      ))}
      <a href="/contacto" class="btn-primary mt-2 text-sm">
        Solicitar información
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });
</script>
