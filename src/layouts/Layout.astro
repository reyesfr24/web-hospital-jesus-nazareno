---
import '../styles/global.css';
import Header from '@/components/sections/Header.astro';
import Footer from '@/components/sections/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'Centro Residencial Hospital Jesús Nazareno. Cuidado y atención especializada para mayores en un entorno de confianza.',
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "NursingHome",
  "name": "Residencia de Ancianos Hospital Jesús Nazareno",
  "url": "https://hospitaljesusnazareno.es",
  "description": description,
  "telephone": "+34 957 12 00 47",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Moreno de Pedrajas, 0",
    "addressLocality": "Villanueva de Córdoba",
    "addressRegion": "Córdoba",
    "postalCode": "14440",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.31858836312276,
    "longitude": -4.630513674855932
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "sameAs": [
    // TODO: añadir URL de Google Business Profile cuando esté creado
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1e4088" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Residencia Hospital Jesús Nazareno</title>
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary-700 focus:text-white focus:rounded">
      Saltar al contenido principal
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
