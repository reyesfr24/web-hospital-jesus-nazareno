---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Contacto" description="Contacta con el Hospital Jesús Nazareno. Solicita información, pide visita o resuelve tus dudas. Te atendemos personalmente.">

  <section class="bg-primary-950 text-white section-padding">
    <div class="section-container">
      <p class="text-warm-300 text-sm font-medium uppercase tracking-widest mb-3">Estamos aquí</p>
      <h1 class="text-white mb-4">Contacto</h1>
      <p class="text-primary-200 text-lg max-w-2xl">
        Llámanos, escríbenos o ven a visitarnos. Estaremos encantados de atenderte.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Formulario -->
        <div>
          <h2 class="text-2xl font-semibold text-gray-900 mb-6">Envíanos un mensaje</h2>
          <!-- Formspree: sustituir YOUR_FORM_ID por el ID real -->
          <form
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-5"
            novalidate
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Nombre <span class="text-red-500" aria-label="obligatorio">*</span>
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  autocomplete="given-name"
                  class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition"
                  placeholder="Tu nombre"
                />
              </div>
              <div>
                <label for="apellidos" class="block text-sm font-medium text-gray-700 mb-1.5">Apellidos</label>
                <input
                  type="text"
                  id="apellidos"
                  name="apellidos"
                  autocomplete="family-name"
                  class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition"
                  placeholder="Tus apellidos"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                Correo electrónico <span class="text-red-500" aria-label="obligatorio">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition"
                placeholder="tu@email.com"
              />
            </div>

            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1.5">Teléfono</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                autocomplete="tel"
                class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition"
                placeholder="600 000 000"
              />
            </div>

            <div>
              <label for="motivo" class="block text-sm font-medium text-gray-700 mb-1.5">Motivo de contacto</label>
              <select
                id="motivo"
                name="motivo"
                class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition bg-white"
              >
                <option value="">Selecciona una opción</option>
                <option value="informacion-plaza">Información sobre plaza</option>
                <option value="visita">Solicitar visita al centro</option>
                <option value="admision">Proceso de admisión</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1.5">
                Mensaje <span class="text-red-500" aria-label="obligatorio">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                required
                rows="5"
                class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition resize-y"
                placeholder="Cuéntanos en qué podemos ayudarte..."
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacidad"
                name="privacidad"
                required
                class="mt-1 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
              />
              <label for="privacidad" class="text-sm text-gray-600">
                He leído y acepto la <a href="/politica-privacidad" class="text-primary-700 underline hover:no-underline">política de privacidad</a>.
                <span class="text-red-500" aria-label="obligatorio">*</span>
              </label>
            </div>

            <!-- Honeypot antispam -->
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

            <button type="submit" class="btn-primary w-full sm:w-auto px-8 py-3">
              Enviar mensaje
            </button>
          </form>
        </div>

        <!-- Datos de contacto -->
        <div class="space-y-8">
          <h2 class="text-2xl font-semibold text-gray-900">Información de contacto</h2>

          <address class="not-italic space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 shrink-0 flex items-center justify-center bg-primary-100 rounded-lg text-primary-700" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Dirección</p>
                <p class="text-gray-600">Calle del Centro, 1<br />Ciudad, Provincia, 00000</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 shrink-0 flex items-center justify-center bg-primary-100 rounded-lg text-primary-700" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Teléfono</p>
                <a href="tel:+34000000000" class="text-primary-700 hover:underline">+34 000 000 000</a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 shrink-0 flex items-center justify-center bg-primary-100 rounded-lg text-primary-700" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <a href="mailto:info@hospitaljesusnazareno.es" class="text-primary-700 hover:underline">info@hospitaljesusnazareno.es</a>
              </div>
            </div>
          </address>

          <div>
            <p class="font-medium text-gray-900 mb-2">Horario de atención</p>
            <p class="text-gray-600 text-sm">Lunes a viernes: 09:00 – 14:00 / 15:00 – 18:00<br />Fines de semana: consultar</p>
          </div>

          <!-- TODO: Insertar mapa de Google Maps embed aquí -->
          <div class="h-56 bg-gray-200 rounded-xl flex items-center justify-center text-gray-400 text-sm">
            [Mapa — pendiente de insertar]
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
