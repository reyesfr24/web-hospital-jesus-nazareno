---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await noticia.render();

const categorias: Record<string, string> = {
  'residente-del-mes': 'Residente del mes',
  'actividades': 'Actividades',
  'salud': 'Consejos de salud',
  'cumpleanos': 'Cumpleaños',
  'menu': 'Menú del mes',
};
---

<Layout title={noticia.data.titulo} description={noticia.data.descripcion}>

  <article>
    <!-- Cabecera -->
    <header class="bg-primary-950 text-white section-padding">
      <div class="section-container max-w-3xl">
        <nav aria-label="Ruta de navegación" class="mb-4">
          <ol class="flex items-center gap-2 text-sm text-primary-300">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/noticias" class="hover:text-white transition-colors">Noticias</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-primary-100 truncate">{noticia.data.titulo}</li>
          </ol>
        </nav>

        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-medium text-primary-200 bg-primary-800 px-2.5 py-1 rounded-full">
            {categorias[noticia.data.categoria] ?? noticia.data.categoria}
          </span>
          <time datetime={noticia.data.fecha.toISOString()} class="text-sm text-primary-300">
            {noticia.data.fecha.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>

        <h1 class="text-white">{noticia.data.titulo}</h1>
        <p class="text-primary-200 text-lg mt-3">{noticia.data.descripcion}</p>
      </div>
    </header>

    <!-- Imagen destacada -->
    {noticia.data.imagen && (
      <div class="section-container max-w-3xl mt-8">
        <img
          src={noticia.data.imagen}
          alt=""
          class="w-full rounded-xl aspect-video object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- Contenido -->
    <div class="section-padding">
      <div class="section-container max-w-3xl prose prose-lg prose-gray prose-headings:font-semibold prose-a:text-primary-700">
        <Content />
      </div>
    </div>

    <!-- Volver -->
    <div class="section-container max-w-3xl pb-12">
      <a href="/noticias" class="btn-outline inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver a noticias
      </a>
    </div>
  </article>

</Layout>
