{
  "$ref": "#/definitions/noticias",
  "definitions": {
    "noticias": {
      "type": "object",
      "properties": {
        "titulo": {
          "type": "string"
        },
        "descripcion": {
          "type": "string"
        },
        "fecha": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "categoria": {
          "type": "string",
          "enum": [
            "residente-del-mes",
            "actividades",
            "salud",
            "cumpleanos",
            "menu"
          ]
        },
        "imagen": {
          "type": "string"
        },
        "destacada": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "titulo",
        "descripcion",
        "fecha",
        "categoria"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
